NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev identity — swap to simulate different roles/orgs
# Must be valid UUIDs (backend casts via uuid.UUID())
NEXT_PUBLIC_DEV_ORG_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-0000-0000-000000000010
NEXT_PUBLIC_DEV_USER_ROLE=admin

# Supabase (client-side — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
